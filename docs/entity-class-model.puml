  regenerating
}

enum SoilType {
  clay
  greasy
  peaty
  rocky
  sandy
}

enum TaskType {
  buy
  fertilize
  harvest
  planting
  rest
  spray
  transplant
  watering
}

enum TaskState {
  pending
  completed
  canceled
}

